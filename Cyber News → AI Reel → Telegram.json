    {
      "parameters": {
        "jsCode": "const items = $input.all();\nif (!items.length) { return []; }\nconst a = items[0].json;\nconst strip = (s) => (s || '').toString().replace(/<[^>]*>/g, ' ').replace(/\\s+/g, ' ').trim();\nreturn [{\n  json: {\n    title: strip(a.title).slice(0, 200),\n    summary: strip(a.contentSnippet || a.content || a.description).slice(0, 1200),\n    link: a.link || '',\n    pubDate: a.pubDate || a.isoDate || '',\n  },\n}];"
      },
      "id": "fce5c490-d68d-464d-9557-3d71193308ef",
      "name": "Pick Latest Article",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        448,
        80
      ]
    },
    {
      "parameters": {
        "modelId": {
          "__rl": true,
          "mode": "list",
          "value": "models/gemini-2.5-flash",
          "cachedResultName": "gemini-2.5-flash"
        },
        "messages": {
          "values": [
            {
              "content": "=TITLE: {{ $json.title }}\n\nSUMMARY: {{ $json.summary }}\n\nSOURCE: {{ $json.link }}"
            }
          ]
        },
        "builtInTools": {},
        "options": {
          "systemMessage": "You are a social media scriptwriter for a cybersecurity channel. Given a news article, write a punchy 30-second vertical-video voiceover script (about 70-90 words, spoken, no stage directions) and a separate social caption with 3-5 relevant hashtags. Respond ONLY with minified JSON of the form {\"script\":\"...\",\"caption\":\"...\",\"title\":\"...\"} and nothing else.",
          "maxOutputTokens": 1024,
          "temperature": 0.7
        }
      },
      "id": "4ba6f203-6454-4e79-b4f4-dfdb60dddd1d",
      "name": "Gemini Write Script",
      "type": "@n8n/n8n-nodes-langchain.googleGemini",
      "typeVersion": 1.2,
      "position": [
        672,
        80
      ],
      "credentials": {
        "googlePalmApi": {
          "id": "VMaXyMFHfJZgPV8M",
          "name": "Google Gemini(PaLM) Api account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const c = $json.content;\nlet raw;\nif (typeof c === 'string') {\n  raw = c;\n} else if (c && c.parts && c.parts[0] && c.parts[0].text) {\n  raw = c.parts[0].text;\n} else if (c && c[0] && c[0].text) {\n  raw = c[0].text;\n} else {\n  raw = $json.text || '{}';\n}\nraw = raw.replace(/```json/gi, '').replace(/```/g, '').trim();\nlet parsed;\ntry {\n  const match = raw.match(/\\{[\\s\\S]*\\}/);\n  parsed = JSON.parse(match ? match[0] : raw);\n} catch (e) {\n  parsed = { script: raw, caption: '', title: '' };\n}\nconst src = $('Pick Latest Article').first().json;\nreturn [{\n  json: {\n    script: (parsed.script || '').toString().trim(),\n    caption: (parsed.caption || '').toString().trim(),\n    title: (parsed.title || src.title || 'Cyber News').toString().trim(),\n    link: src.link || '',\n  },\n}];"
      },
      "id": "df7344e0-2fae-48f6-91e7-3a6df9c14d48",
      "name": "Parse Script JSON",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        896,
        80
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.json2video.com/v2/movies",
        "authentication": "genericCredentialType",
