        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ resolution: \"instagram-story\", quality: \"high\", scenes: [ { comment: \"main\", elements: [ { type: \"text\", text: $json.title, style: \"005\", position: \"center-center\", start: 0, duration: 3 }, { type: \"voice\", text: $json.script, voice: \"en-US-AriaNeural\" } ] } ] }) }}",
        "options": {}
      },
