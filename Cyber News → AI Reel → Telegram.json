    {
      "parameters": {
        "jsCode": "const movie = $json.movie || {};\nif (movie.status !== 'done' || !movie.url) {\n  throw new Error('Video render did not complete: ' + JSON.stringify(movie));\n}\nconst s = $('Parse Script JSON').first().json;\nreturn [{\n  json: {\n    video_url: movie.url,\n    caption: s.caption || s.title,\n    title: s.title,\n  },\n}];"
      },
